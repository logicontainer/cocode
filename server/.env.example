# -----------------------------------------------------------------------------
# APPLICATION ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values before running docker compose up
# -----------------------------------------------------------------------------

# The port the application will run on (Default: 3000)
PORT=3000

# NextAuth / Authentication Secrets (Generate a secure random string)
# You can generate one via: openssl rand -base64 32
NEXTAUTH_SECRET=your_secure_random_string_here
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# If you are using the bundled PostgreSQL container in the docker-compose.yml:
POSTGRES_USER=admin
POSTGRES_PASSWORD=super_secure_database_password
POSTGRES_DB=cocode_app_db

# The connection string the application uses to connect to the database.
# If using the bundled DB, this must match the credentials above.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql://admin:super_secure_database_password@db:5432/cocode_app_db
DATABASE_URL=postgresql://postgres:fdssdkfjhsdfgosdu32423r4g@db.plqyquaewdfrmcnfxpzx.supabase.co:5432/postgres

# NOTE FOR ENTERPRISE IT:
# If you are dropping the bundled 'db' container and using your own managed
# PostgreSQL cluster, change the DATABASE_URL above to point to your cluster.
